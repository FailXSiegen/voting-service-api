{
  "name": "voting-service-api",
  "version": "2.0.1",
  "description": "Voting service API",
  "main": "main.js",
  "scripts": {
    "serve": "babel-watch ./src",
    "dev": "babel-watch ./src",
    "copy": "cp -avr src/lib/emails/ dist/lib/",
    "build": "babel src --out-dir dist && npm run copy",
    "db:migrate": "node_modules/.bin/db-migrate up",
    "db:backup": "node scripts/backup-db.js",
    "db:restore": "node scripts/restore-db.js",
    "lint": "eslint --ext .js --ignore-path .gitignore --fix src",
    "lint:check": "eslint --ext .js --ignore-path .gitignore src",
    "format": "prettier src --write",
    "format:check": "prettier src --check",
    "lint:debug": "bash bin/find-forbidden-words.sh",
    "qa": "npm run lint:check && npm run format:check && npm run lint:debug",
    "qa:cpd": "jscpd src",
    "qa:unused": "knip",
    "qa:all": "npm run qa && npm run qa:cpd && npm run qa:unused",
    "before:commit": "npm run lint:check && npm run lint:debug && npm run format:check",
    "prepare": "husky",
    "setup-testdata": "babel-node scripts/test-setup.js",
    "clear-shortlinks": "babel-node src/scripts/clear-shortlinks.js"
  },
  "keywords": [],
  "author": "Wolf Utz",
  "license": "MIT",
  "dependencies": {
    "@babel/core": "^7.11.6",
    "apollo-errors": "^1.9",
    "argon2": "^0.41.1",
    "cookie-parser": "^1.4.5",
    "cors": "^2.8.5",
    "db-migrate": "^0.11.14",
    "db-migrate-mysql": "^3.0",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "fast-csv": "^4.3.6",
    "graphql-ws": "^5.11.2",
    "graphql-yoga": "^3.1.1",
    "humps": "^2.0.1",
    "jsonwebtoken": "^9.0.2",
    "jsrsasign": "^11.0",
    "md5": "^2.3.0",
    "minimist": "^1.2.5",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.4",
    "nodemailer-pug-engine": "^2.0.1",
    "promise-mysql": "^4.1.3",
    "uuid": "^9.0.1",
    "ws": "^8.9.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.14.5",
    "@babel/node": "^7.10.5",
    "@babel/preset-env": "^7.11.0",
    "babel-plugin-import-graphql": "^2.7.0",
    "babel-watch": "^7.8.1",
    "cross-env": "^5.2.0",
    "eslint": "^8.51.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^6.3.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.0"
  },
  "overrides": {
    "cross-undici-fetch": "0.4.8",
    "path-to-regexp": "0.1.13"
  },
  "engines": {
    "npm": ">=9.0.0",
    "node": ">=18.0.0"
  }
}
